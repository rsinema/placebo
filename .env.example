# Environment: 'dev' uses TEST_* tokens, 'prod' uses TELEGRAM_* and ANALYTICS_* tokens
PLACEBO_ENV=dev

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TEST_BOT_TOKEN=your-test-bot-token

# Moonshot AI (Kimi)
MOONSHOT_API_KEY=your-moonshot-api-key

# Postgres
POSTGRES_USER=placebo
POSTGRES_PASSWORD=placebo
POSTGRES_DB=placebo
DATABASE_URL=postgresql://placebo:placebo@db:5432/placebo

# Check-in schedule (24h format, in UTC)
CHECKIN_HOUR=14
CHECKIN_MINUTE=0

# Analytics bot
ANALYTICS_BOT_TOKEN=your-analytics-bot-token
TEST_ANALYTICS_BOT_TOKEN=your-test-analytics-bot-token
ANALYTICS_DIGEST_DAY=0   # 0=Monday, 1=Tuesday, ..., 6=Sunday
ANALYTICS_DIGEST_HOUR=9
ANALYTICS_DIGEST_MINUTE=0

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=placebo
