# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Gym bot
GYM_TELEGRAM_BOT_TOKEN=your-gym-bot-token

# Moonshot AI (Kimi)
MOONSHOT_API_KEY=your-moonshot-api-key

# Postgres
POSTGRES_USER=placebo
POSTGRES_PASSWORD=placebo
POSTGRES_DB=placebo
DATABASE_URL=postgresql://placebo:placebo@db:5432/placebo

# Check-in schedule (24h format, timezone from IANA tz database, e.g. "UTC", "America/Denver", "Europe/London")
CHECKIN_HOUR=14
CHECKIN_MINUTE=0
CHECKIN_TIMEZONE=UTC

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=placebo

# S3 backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BACKUP_S3_BUCKET=
# Optional: customize layout / schedule / retention
# BACKUP_S3_PREFIX=placebo
# BACKUP_RETENTION_DAYS=30
# BACKUP_HOUR_UTC=10
# Optional: S3-compatible endpoint (R2, B2, MinIO). Leave blank for AWS S3.
# BACKUP_S3_ENDPOINT_URL=
